  "voting": {
    "confidenceWeights": {
      "high": 1.0,
      "medium": 0.75,
      "low": 0.5
    },
    "domainSeatMultiplier": 1.5,
    "consensusThreshold": 0.667
  },
  "enforcement": {
    "dissentQuota": 2,
    "noveltyRequired": true,
    "evidenceDiversityThreshold": 0.8,
    "engagementRequired": true
  },
  "settings": {
    "minAdvisors": 4,
    "maxAdvisors": 6,
    "defaultAdvisors": 5,
    "alwaysIncludeChallenger": true,
    "alwaysIncludePolarityPair": true,
    "challengerAdvisors": [
      "questioner",
      "subtractor",
      "reframer",
      "provocateur",
      "devil's-advocate"
    ],
    "defaultMode": "full",
    "defaultCrossExam": "sparse",
    "earlyTermination": true
  },
  "costBudget": {
    "tiers": {
      "minimal": {
        "maxTokens": 3000,
        "mode": "duo",
        "advisors": 2,
        "crossExam": "none"
      },
      "lean": {
        "maxTokens": 8000,
        "mode": "quick",
        "advisors": 4,
        "crossExam": "sparse"
      },
      "standard": {
        "maxTokens": 15000,
        "mode": "quick",
        "advisors": 5,
        "crossExam": "sparse"
      },
      "full": {
        "maxTokens": 25000,
        "mode": "full",
        "advisors": 5,
        "crossExam": "sparse"
      },
      "deep": {
        "maxTokens": 40000,
        "mode": "full",
        "advisors": 6,
        "crossExam": "all-pairs"
      },
      "unlimited": {
        "maxTokens": null,
        "mode": "full",
        "advisors": 6,
        "crossExam": "all-pairs"
      }
    },
    "defaultTier": "full",
    "wordLimitScaling": {
      "minimal": 0.4,
      "lean": 0.6,
      "standard": 0.8,
      "full": 1.0,
      "deep": 1.0,
      "unlimited": 1.0
    }
  },
  "factChecker": {
    "enabled": true,
    "maxFlags": 5,
    "flagTypes": [
      "verified",
      "unverifiable",
      "disputed"
    ],
    "exemptContent": [
      "opinions",
      "recommendations",
      "analogies",
      "thought-experiments"
    ]
  },
  "analytics": {
    "enabled": true,
    "autoTrackOnBudgetMode": true,
    "storageFormat": "council-analytics-{date}.json",
    "metrics": [
      "position_changes",
      "influence_map",
      "enforcement_scan",
      "consensus_strength",
      "early_termination",
      "fact_checker",
      "token_usage"
    ]
  },
  "multiModel": {
    "enabled": true,
    "mode": "auto",
    "diversityThreshold": 0.5,
    "evidenceTypeModelMapping": {
      "empirical": "model-a",
      "mechanistic": "model-b",
      "strategic": "model-c",
      "heuristic": "model-a",
      "ethical": "model-b",
      "experiential": "model-c",
      "generative": "model-a"
    },
    "modelSlots": {
      "model-a": { "description": "Primary model (auto-detected from client)", "strengths": ["analysis", "creativity", "nuance"] },
      "model-b": { "description": "Secondary model (if available)", "strengths": ["logic", "systems", "formal"] },
      "model-c": { "description": "Tertiary model (if available)", "strengths": ["planning", "adversarial", "game-theory"] }
    },
    "fallback": {
      "singleModelDiversity": true,
      "reasoningVariation": ["analytical", "creative", "adversarial", "empathetic", "systematic"],
      "description": "When only one model is available, vary prompting strategy per evidence type to simulate cognitive diversity"
    },
    "userOverride": {
      "description": "Users can override by setting availableModels array with actual model names",
      "example": {
        "availableModels": ["claude-sonnet-4", "gpt-4o", "gemini-2.5-pro"],
        "mapping": {
          "model-a": "claude-sonnet-4",
          "model-b": "gpt-4o",
          "model-c": "gemini-2.5-pro"
        }
      }
    }
  },
  "interactiveMode": {
    "enabled": false,
    "description": "When true, all council sessions include checkpoints. When false (default), only triggered by 'interactive council:' or 'council this with checkpoints:'",
    "checkpoints": {
      "afterRound1": true,
      "afterRound2": true,
      "afterCrystallization": false
    },
    "userActions": ["continue", "inject", "remove", "redirect", "skip-to-verdict"],
    "defaultAction": "continue",
    "maxCheckpoints": 2
  },
  "persistentMemory": {
    "enabled": true,
    "transcriptDir": "council-transcripts",
    "autoSaveOnBudgetMode": true,
    "autoSaveAlways": false,
    "outcomeTracking": {
      "enabled": true,
      "minOutcomesForCalibration": 5,
      "minSessionsPerAdvisor": 3
    },
    "calibration": {
      "enabled": true,
      "adjustWeightsAutomatically": false,
      "reportThreshold": 5
    }
  },
  "sparseExamination": {
    "defaultEnabled": true,
    "engagementsPerAdvisor": {
      "panel4": 3,
      "panel5": 2,
      "panel6": 3
    },
    "assignmentPriority": [
      "polarity_pair",
      "evidence_diversity",
      "similarity_check"
    ],
    "fallbackToAllPairs": [
      "panel4",
      "user_request",
      "enforcement_failure"
    ]
  },
  "earlyTermination": {
    "enabled": true,
    "conditions": {
      "consensusThreshold": 0.8,
      "requiredConfidence": "high",
      "noDealbreaker": true,
      "enforcementPassed": true
    },
    "overrideKeywords": [
      "thorough",
      "deep dive",
      "full deliberation"
    ],
    "tokenSavingsEstimate": "30-40%"
  },
  "roadmap": {
    "planned": [
      {
        "feature": "multi-model-support",
        "description": "Allow different LLM backends per advisor for true reasoning diversity",
        "priority": "high",
        "status": "implemented"
      },
      {
        "feature": "persistent-memory",
        "description": "Cross-session transcript storage and pattern learning",
        "priority": "medium",
        "status": "implemented"
      },
      {
        "feature": "human-in-the-loop",
        "description": "Allow user intervention during deliberation rounds, not just after verdict",
        "priority": "medium",
        "status": "implemented"
      },
      {
        "feature": "confidence-calibration",
        "description": "Calibrate confidence scores against outcomes over time",
        "priority": "low",
        "status": "implemented"
      }
    ]
  }
}
